VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key

# Legacy projects can use VITE_SUPABASE_ANON_KEY instead of VITE_SUPABASE_PUBLISHABLE_KEY.
# Never put a service_role or secret key in this browser app.

# Local Supabase example after `npx supabase start`:
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_PUBLISHABLE_KEY=<copy the local Publishable key from `npx supabase status`>

# Local-only helper for pushing hosted DB migrations.
# Put the real value in `.env`, never in git, chat, or memory-bank notes.
# SUPABASE_DB_PASSWORD=<your hosted database password>
