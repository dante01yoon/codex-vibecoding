{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/travel-plan.schema.json",
  "title": "Travel Plan",
  "description": "A JSON Schema for a travel plan.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "destinationName",
    "dailyItinerary",
    "recommendedAccommodation",
    "estimatedTotalCost",
    "packingList"
  ],
  "properties": {
    "destinationName": {
      "type": "string",
      "minLength": 1,
      "description": "The name of the travel destination."
    },
    "dailyItinerary": {
      "type": "array",
      "minItems": 1,
      "description": "Daily itinerary entries grouped by date.",
      "items": {
        "$ref": "#/$defs/dailySchedule"
      }
    },
    "recommendedAccommodation": {
      "type": "string",
      "minLength": 1,
      "description": "Recommended accommodation for the trip."
    },
    "estimatedTotalCost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "currency"
      ],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0,
          "description": "Estimated total travel cost."
        },
        "currency": {
          "type": "string",
          "minLength": 1,
          "description": "Currency code or label for the estimated cost."
        }
      },
      "description": "Estimated total cost for the trip."
    },
    "packingList": {
      "type": "array",
      "description": "Items to prepare before the trip. Duplicates should be avoided.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "dailySchedule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "place",
        "activity"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date of the itinerary entry in YYYY-MM-DD format."
        },
        "place": {
          "type": "string",
          "minLength": 1,
          "description": "Place to visit on the given date."
        },
        "activity": {
          "type": "string",
          "minLength": 1,
          "description": "Description of the planned activity."
        }
      }
    }
  }
}
