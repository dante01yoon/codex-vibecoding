# Browser-safe Supabase config. Do not put service_role or provider secrets here.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional override when the frontend should call a separate API host.
# Leave empty during Vite dev because vite.config.js proxies /api to the local server.
VITE_STOCK_API_BASE_URL=

# Market data provider mode exposed to the browser.
# demo: use bundled sample data only.
# auto: use Alpha Vantage for US and KIS for KR, then fall back to demo on setup/rate errors.
# alpha-vantage: force Alpha Vantage.
# kis: force Korea Investment Open API.
VITE_MARKET_DATA_PROVIDER=auto

# Local market-data proxy.
STOCK_API_HOST=127.0.0.1
STOCK_API_PORT=8787

# Real provider credentials stay on the local server only.
ALPHA_VANTAGE_API_KEY=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCESS_TOKEN=
